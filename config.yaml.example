env_file: .env
oracle:
  dsn: ${ORACLE_DSN}
  host: ${ORACLE_HOST}
  port: ${ORACLE_PORT}
  service_name: ${ORACLE_SERVICE_NAME}
  sid: ${ORACLE_SID}
  user: ${ORACLE_USER}
  password: ${ORACLE_PASSWORD}
  schema: ${ORACLE_SCHEMA}
  client_lib_dir: ${ORACLE_CLIENT_LIB_DIR}
postgres:
  host: ${PG_HOST}
  port: ${PG_PORT}
  database: ${PG_DATABASE}
  user: ${PG_USER}
  password: ${PG_PASSWORD}
  schema: ${PG_SCHEMA:-public}
sync:
  default_direction: oracle-to-postgres
  default_mode: truncate_safe
  dry_run: true
  fast_count: true
  exact_count_after_load: false
  parallel_workers: 1
  batch_size: 10000
  chunk_size: 50000
  skip_on_structure_mismatch: true
  build_indexes_on_staging: true
  analyze_after_load: true
  truncate_cascade: false
  allow_swap: false
  max_swap_table_bytes: 20GiB
  swap_space_multiplier: 2.5
  keep_old_after_swap: false
  copy_null: ''
  pg_lock_timeout: 5s
  pg_statement_timeout: '0'
  checkpoint_dir: reports/checkpoints/checkpoint.sqlite3
  truncate_resume_strategy: restart_table
  staging_schema: null
  backup_before_truncate: true
  backup_retention_count: 3
  staging_retention_count: 5
  max_failures: 3
  cooldown_minutes: 30
reports:
  output_dir: reports
dependency:
  auto_recompile_oracle: true
  refresh_postgres_mview: true
  max_recompile_attempts: 3
  max_attempts: 3
  fail_on_broken_dependency: true
job:
  name: oracle_to_pg_daily
  retry: 3
  timeout_seconds: 3600
  alert_command: echo FAILED
  alert:
    type: webhook
    url: ''
    on:
      - failure
      - repeated_failure
      - dependency_error
    timeout_seconds: 10
validation:
  checksum:
    enabled: false
    mode: table
    batch_size: 5000
    chunk_key: null
    columns: auto
    exclude_columns: []
    sample_percent: 1
lob_strategy:
  default: error
  stream_batch_size: 100
  lob_chunk_size_bytes: 1048576
  validation:
    default: size
    hash_algorithm: sha256
  warn_on_lob_larger_than_mb: 50
  fail_on_lob_larger_than_mb: null
  columns: {}
rename_columns:
  public.sample_customer:
    legacy_status: status
  public.sample_order:
    legacy_note: note_text
tables_file: configs/tables.example.yaml

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

PROJECT_DIR=/path/to/oracle-pg-sync-audit

# Keep PostgreSQL close to Oracle for critical cutoff tables.
# The wrapper syncs data, adjusts PostgreSQL sequences from Oracle, then validates rowcount.
# This job exits non-zero when sequence sync fails or exact validation still finds a mismatch.
0 1 * * * cd "$PROJECT_DIR" && mkdir -p reports/job_logs && TIMEOUT_SECONDS=21600 RETRY=1 jobs/production_keepup.sh oracle_to_pg >> reports/job_logs/daily_oracle_to_pg.log 2>&1

# Site-specific reference/reverse jobs should live in ignored private scripts
# or a private crontab snippet. Do not commit production table names, keys, or
# internal schedules to this public example.

# Do not enable cutoff as a regular cron.
# Run manually inside the approved freeze window:
# cd "$PROJECT_DIR" && FREEZE_CONFIRMED=yes TIMEOUT_SECONDS=21600 jobs/production_cutoff.sh oracle_to_pg

# Run from the repository checkout. Logs are written to reports/job_logs/.
SHELL=/bin/bash
CONFIG_PATH=/home/app/oracle-pg-sync-audit/config.yaml
# Optional alert command. It receives ALERT_MESSAGE in the environment.
# ALERT_COMMAND='printf "%s\n" "$ALERT_MESSAGE" | mail -s "oracle-pg-sync failed" dba@example.com'

# Full dependency-safe refresh once per day.
15 1 * * * cd /home/app/oracle-pg-sync-audit && jobs/daily.sh

# Incremental upsert every five minutes.
*/5 * * * * cd /home/app/oracle-pg-sync-audit && jobs/every_5min.sh --direction postgres-to-oracle --tables public.address --key-columns address_id --incremental-column last_update

# Add one line per reverse table when each table has different key/filter rules.
# */5 * * * * cd /home/app/oracle-pg-sync-audit && jobs/every_5min.sh --direction postgres-to-oracle --tables public.housemaster --key-columns site_id --incremental-column last_update

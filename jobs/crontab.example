# Run from the repository checkout. Logs are written to reports/job_logs/.
SHELL=/bin/bash
CONFIG_PATH=/home/app/oracle-pg-sync-audit/config.yaml
RETRY=3
TIMEOUT_SECONDS=3600
LOG_ROTATE_BYTES=10485760
LOG_RETENTION_DAYS=14
# Optional alert command. It receives ALERT_MESSAGE in the environment.
# ALERT_COMMAND='printf "%s\n" "$ALERT_MESSAGE" | mail -s "oracle-pg-sync failed" dba@example.com'

# Full dependency-safe refresh once per day in both directions.
15 1 * * * cd /home/app/oracle-pg-sync-audit && jobs/daily.sh oracle_to_pg
45 1 * * * cd /home/app/oracle-pg-sync-audit && jobs/daily.sh pg_to_oracle

# Incremental sync every five minutes in both directions.
*/5 * * * * cd /home/app/oracle-pg-sync-audit && jobs/incremental.sh oracle_to_pg
*/5 * * * * cd /home/app/oracle-pg-sync-audit && jobs/incremental.sh pg_to_oracle --tables public.address --mode upsert --key-columns address_id --incremental-column last_update

# Copy table-specific wrappers when reverse incremental filters differ by table.

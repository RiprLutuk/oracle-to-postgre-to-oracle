# Run from the repository checkout. Logs are written to reports/job_logs/.
SHELL=/bin/bash
CONFIG_PATH=/home/app/oracle-pg-sync-audit/config.yaml
RETRY=3
TIMEOUT_SECONDS=3600
LOG_ROTATE_BYTES=10485760
LOG_RETENTION_DAYS=14
# Optional alert command. It receives ALERT_MESSAGE in the environment.
# ALERT_COMMAND='printf "%s\n" "$ALERT_MESSAGE" | mail -s "oracle-pg-sync failed" dba@example.com'

# Full dependency-safe Oracle -> PostgreSQL refresh once per day.
15 1 * * * cd /home/app/oracle-pg-sync-audit && jobs/daily.sh oracle_to_pg

# PostgreSQL -> Oracle daily uses full replace by profile default. Enable only
# with explicit table scope and app owner approval.
# 45 1 * * * cd /home/app/oracle-pg-sync-audit && jobs/daily.sh pg_to_oracle --tables public.small_reference_table --mode truncate

# Incremental sync every five minutes.
*/5 * * * * cd /home/app/oracle-pg-sync-audit && jobs/incremental.sh oracle_to_pg
*/5 * * * * cd /home/app/oracle-pg-sync-audit && jobs/incremental.sh pg_to_oracle --tables public.sample_customer --mode upsert --key-columns customer_id --incremental

# Per-2-minute reverse wrapper can use TABLE_SPECS third field "auto" to detect
# update/create timestamp columns, including COALESCE(update_col, create_col).
# */2 * * * * cd /home/app/oracle-pg-sync-audit && mkdir -p reports/job_logs/pg_to_oracle_2min && P2O_DRY_RUN=0 jobs/pg_to_oracle_every_2min.sh >> reports/job_logs/pg_to_oracle_2min/cron.log 2>&1
